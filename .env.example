# Sports Jarvis — environment template. Copy to .env and fill in real keys.
# The app boots with all keys blank: it falls back to a deterministic demo
# slate and disables audio playback until ElevenLabs is configured.

# Odds + stats data sources
API_SPORTS_KEY=
ODDS_API_KEY=
OPENWEATHER_API_KEY=
BALLDONTLIE_API_KEY=

# Analyst brief generation (Claude Opus, extended thinking)
ANTHROPIC_API_KEY=

# Voice brief synthesis (ElevenLabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Display / operating-day timezone (IANA zone). Drives every date label and the
# 6 AM operating-day boundary, server-side. Defaults to America/New_York.
DISPLAY_TIMEZONE=America/New_York
# Client mirror — Vite only exposes vars prefixed with VITE_. Keep in sync with
# DISPLAY_TIMEZONE so server and browser format dates in the same zone.
VITE_DISPLAY_TIMEZONE=America/New_York

# Staking
BANKROLL_USD=29000

# Player props — flat stake per prop pick (units), held flat until 100+ graded results
PROP_STAKE_UNITS=0.5
